# .env.example
# Supabase — get these from your Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
# Set to 'email' for local dev with email/password auth (default: 'phone')
NUXT_PUBLIC_AUTH_MODE=phone



# Encrypt tenant Moyasar secrets at rest (64 hex chars = 32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Public site URL (for Moyasar webhook registration)
SITE_URL=http://localhost:3000
