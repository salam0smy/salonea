    "@nuxtjs/supabase": "^2.0.4",
    "@pinia/nuxt": "^0.11.3",
    "nuxt": "^4.3.1",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.95",
    "@nuxt/test-utils": "^4.0.0",
